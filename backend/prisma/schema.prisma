generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL_ONLINE")
}

model Users {
  id                    String      @id @default(uuid())
  email                 String      @unique
  role                  Role        @default(user)
  passwordHashed        String?
  name                  String
  createdAt             DateTime    @default(now())
  provider              String      @default("local")
  providerId            String?     @unique
  updatedAt             DateTime    @updatedAt
  bio                   String      @default("")
  campaigns_owned       Campaign[]  @relation("CampaignOwner")
  characters            Character[]
  campaigns_contributed Campaign[]  @relation("CampaignContributors")
}

model Character {
  id                 String                   @id @default(uuid())
  name               String
  ownerId            String
  campaignId         String?
  level              Int                      @default(1)
  xp                 Int                      @default(0)
  background         String?
  alignment          String?
  inspiration        Boolean                  @default(false)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  bonds              String?
  flaws              String?
  ideals             String?
  personalityTraits  String?
  icon               String?
  image              String?
  race               String?
  class              String?
  subrace            String?
  subclass           String?
  campaign           Campaign?                @relation(fields: [campaignId], references: [id])
  owner              Users                    @relation(fields: [ownerId], references: [id])
  combat             CharacterCombatStats?
  currency           CharacterCurrency?
  characterEventLogs CharacterEventLog[]
  features           CharacterFeature[]
  knownSpells        CharacterKnownSpell[]
  preparedSpells     CharacterPreparedSpell[]
  proficiencies      CharacterProficiency[]
  saves              CharacterSaves?
  skills             CharacterSkill[]
  spellSlots         CharacterSpellSlot[]
  stats              CharacterStats?
  inventoryItems     InventoryItem[]
}

model CharacterStats {
  characterId String    @id
  str         Int       @default(10)
  dex         Int       @default(10)
  con         Int       @default(10)
  int         Int       @default(10)
  wis         Int       @default(10)
  cha         Int       @default(10)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterSaves {
  characterId   String    @id
  strProficient Boolean   @default(false)
  dexProficient Boolean   @default(false)
  conProficient Boolean   @default(false)
  intProficient Boolean   @default(false)
  wisProficient Boolean   @default(false)
  chaProficient Boolean   @default(false)
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterSkill {
  id          String    @id @default(uuid())
  characterId String
  name        String
  proficient  Boolean   @default(false)
  expertise   Boolean   @default(false)
  bonus       Int?
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterProficiency {
  id          String    @id @default(uuid())
  characterId String
  type        String
  name        String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterCombatStats {
  characterId       String    @id
  hp                Int       @default(0)
  hpMax             Int       @default(0)
  ac                Int?
  initiative        Int?
  speed             Int?
  hitDiceType       Int?
  hitDiceCurrent    Int?
  hitDiceTotal      Int?
  deathSavesSuccess Int       @default(0)
  deathSavesFail    Int       @default(0)
  passivePerception Int?
  size              Size?
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Item {
  id             String          @id @default(uuid())
  name           String          @unique
  type           String
  description    String?
  weight         Float?
  value          Int?
  properties     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inventoryItems InventoryItem[]
}

model InventoryItem {
  id          String    @id @default(uuid())
  characterId String
  itemId      String
  quantity    Int       @default(1)
  equipped    Boolean   @default(false)
  notes       String?
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  item        Item      @relation(fields: [itemId], references: [id])
}

model Spell {
  id          String                   @id @default(uuid())
  name        String                   @unique
  level       Int
  school      String?
  castingTime String?
  range       String?
  components  String?
  duration    String?
  description String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  knownBy     CharacterKnownSpell[]
  preparedBy  CharacterPreparedSpell[]
}

model CharacterKnownSpell {
  id             String    @id @default(uuid())
  characterId    String
  spellId        String
  learnedAtLevel Int?
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  spell          Spell     @relation(fields: [spellId], references: [id])
}

model CharacterPreparedSpell {
  id          String    @id @default(uuid())
  characterId String
  spellId     String
  preparedAt  DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  spell       Spell     @relation(fields: [spellId], references: [id])
}

model CharacterSpellSlot {
  id          String    @id @default(uuid())
  characterId String
  spellLevel  Int
  maxSlots    Int       @default(0)
  usedSlots   Int       @default(0)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Feature {
  id                String             @id @default(uuid())
  name              String
  description       String?
  sourceType        String?
  sourceId          String?
  characterFeatures CharacterFeature[]
}

model CharacterFeature {
  id              String    @id @default(uuid())
  characterId     String
  featureId       String
  acquiredAtLevel Int?
  notes           String?
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  feature         Feature   @relation(fields: [featureId], references: [id])
}

model Race {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  speed         Int?
  languages     String?
  size          Size?
  raceAbilities RaceAbility[]
  subRaces      SubRace[]
}

model SubRace {
  id               String           @id @default(uuid())
  parentRaceId     String
  name             String           @unique
  description      String?
  parentRace       Race             @relation(fields: [parentRaceId], references: [id])
  subRaceAbilities SubRaceAbility[]
}

model RaceAbility {
  id          String  @id @default(uuid())
  raceId      String
  name        String  @unique
  description String?
  race        Race    @relation(fields: [raceId], references: [id])
}

model SubRaceAbility {
  id          String  @id @default(uuid())
  subRaceId   String
  name        String
  description String?
  subRace     SubRace @relation(fields: [subRaceId], references: [id])
}

model Class {
  id           String             @id @default(uuid())
  name         String             @unique
  hitDie       Int
  spellcasting Boolean            @default(false)
  description  String?
  savingThrows String[]
  progressions ClassProgression[]
  subclasses   Subclass[]
}

model Subclass {
  id          String  @id @default(uuid())
  classId     String
  name        String  @unique
  description String?
  class       Class   @relation(fields: [classId], references: [id])
}

model ClassProgression {
  id         String  @id @default(uuid())
  classId    String
  level      Int
  features   String?
  hpPerLevel Int
  spellSlots Json?
  class      Class   @relation(fields: [classId], references: [id])
}

model CharacterCurrency {
  characterId String    @id
  gp          Int       @default(0)
  sp          Int       @default(0)
  ep          Int       @default(0)
  cp          Int       @default(0)
  pp          Int       @default(0)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Feat {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
}

model CharacterEventLog {
  id          String    @id @default(uuid())
  characterId String
  type        String
  payload     Json?
  createdAt   DateTime  @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           String      @id @default(uuid())
  name         String
  description  String
  joinCode     String
  ownerId      String
  photo        String?
  currentSession Int        @default(0)
  owner        Users       @relation("CampaignOwner", fields: [ownerId], references: [id])
  characters   Character[]
  locations    Location[]
  maps         Map[]
  missions     Mission[]
  npcs         NPC[]
  notes        Note[]
  contributors Users[]     @relation("CampaignContributors")
}

model Note {
  id          String   @id @default(uuid())
  name        String
  description String
  author      String
  date        DateTime
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
}

model Map {
  id          String   @id @default(uuid())
  file        String
  name        String
  description String
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
}

model Mission {
  id               String           @id @default(uuid())
  title            String
  description      String
  campaignId       String
  isPublic         Boolean          @default(true)
  status           MissionStatus
  campaign         Campaign         @relation(fields: [campaignId], references: [id])
  missionNpcs      MissionNpc[]
  missionLocations MissionLocation[]
}

model Location {
  id               String           @id @default(uuid())
  name             String
  description      String
  campaignId       String
  isPublic         Boolean          @default(true)
  campaign         Campaign         @relation(fields: [campaignId], references: [id])
  missionLocations MissionLocation[]
  npcs             NPC[]            @relation("LocationToNPC")
}

model NPC {
  id          String       @id @default(uuid())
  name        String
  description String
  isPublic    Boolean      @default(true)
  campaignId  String
  missionNpcs MissionNpc[]
  campaign    Campaign     @relation(fields: [campaignId], references: [id])
  locations   Location[]   @relation("LocationToNPC")
}

model MissionNpc {
  MissionId String
  npcId     String
  mission   Mission @relation(fields: [MissionId], references: [id], onDelete: Cascade)
  npc       NPC     @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@id([MissionId, npcId])
}

model MissionLocation {
  MissionId  String
  LocationId String
  mission    Mission  @relation(fields: [MissionId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [LocationId], references: [id], onDelete: Cascade)

  @@id([MissionId, LocationId])
}

model Monster {
  id                    String   @id @default(uuid())
  apiId                 String   @unique
  name                  String
  size                  Size?
  type                  String
  subtype               String?
  alignment             String?
  armorClass            Int?
  hitPoints             Int?
  hitDice               String?
  speed                 Json?
  stats                 Json?
  actions               Json?
  legendaryActions      Json?
  specialAbilities      Json?
  languages             String?
  challengeRating       Float?
  xp                    Int?
  senses                Json?
  damageImmunities      String?
  conditionImmunities   String?
  damageResistances     String?
  damageVulnerabilities String?
  savingThrows          Json?
  skills                Json?
  reactions             Json?
  environment           String?
  image                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum Role {
  user
  admin
}

enum Size {
  Tiny
  Small
  Medium
  Large
  Huge
  Gargantuan
}

enum Alignment {
  chaotic_good
  chaotic_evil
  chaotic_neutral
  neutral
  lawful_neutral
  lawful_evil
  lawful_good
  neutral_good
  neutral_evil
}

enum MissionStatus {
  pending
  in_progress
  completed
}
